prometheus:
  ingress:
    enabled: true
    ingressClassName: "{{ ingress_class_name }}"
    annotations:
      nginx.ingress.kubernetes.io/rewrite-target: /
    hosts:
      - "{{ prometheus_ingress_host }}"
    paths:
      - /
      
  prometheusSpec:
    storageSpec:
      volumeClaimTemplate:
        spec:
          accessModes: ["ReadWriteOnce"]
          resources:
            requests:
              storage: {{ prometheus_storage }}
          {% if storage_class %}
          storageClassName: "{{ storage_class }}"
          {% endif %}

grafana:
  enabled: true
  adminUser: "{{ grafana_admin_user }}"
  adminPassword: "{{ grafana_admin_password }}"
  persistence:
    enabled: true
    size: {{ grafana_storage }}
    {% if storage_class %}
    storageClassName: "{{ storage_class }}"
    {% endif %}
  
  ingress:
    enabled: true
    ingressClassName: "{{ ingress_class_name }}"
    annotations:
      nginx.ingress.kubernetes.io/rewrite-target: /
    hosts:
      - "{{ grafana_ingress_host }}"
    path: /


alertmanager:
  alertmanagerSpec:
    storage:
      volumeClaimTemplate:
        spec:
          accessModes: ["ReadWriteOnce"]
          resources:
            requests:
              storage: {{ alertmanager_storage }}
          {% if storage_class %}
          storageClassName: "{{ storage_class }}"
          {% endif %}

# Disable heavy components for minimal setup
kubeApiServer:
  enabled: false

kubeControllerManager:
  enabled: false

kubeScheduler:
  enabled: false

kubeEtcd:
  enabled: false
